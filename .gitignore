# ============================================================================
# DATA FILES
# ============================================================================

# Raw data (never commit)
data/raw/*
!data/raw/.gitkeep

# Processed data (reproducible, don't commit)
data/processed/*
!data/processed/.gitkeep

# External data
data/external/*
!data/external/.gitkeep

# Common data formats
*.csv
*.tsv
*.xlsx
*.xls
*.parquet
*.feather
*.arrow
*.orc
*.avro

# Serialised objects
*.pickle
*.pkl
*.joblib

# HDF5
*.h5
*.hdf5
*.hdf

# SQLite
*.sqlite
*.sqlite3
*.db

# Large binary files
*.npy
*.npz
*.pt
*.pth
*.onnx
*.safetensors

# Compressed archives (often data)
*.zip
*.tar
*.tar.gz
*.tgz
*.7z
*.rar


